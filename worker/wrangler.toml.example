name = "exam-wizard-next-proxy"
main = "src/index.js"
compatibility_date = "2026-06-15"

[vars]
ALLOWED_ORIGIN = "http://localhost:8000"
GEMINI_API_VERSION = "v1beta"
GEMINI_MODEL = "gemini-3.5-flash"
GEMINI_TIMEOUT_MS = "300000"

[[d1_databases]]
binding = "GENERATION_JOBS_DB"
database_name = "exam-wizard-generation-jobs"
database_id = "<D1_DATABASE_ID>"
migrations_dir = "migrations"

[[workflows]]
name = "exam-wizard-generation-workflow"
binding = "GENERATION_WORKFLOW"
class_name = "GenerationWorkflow"

# Set the Gemini API key before deploying:
# npx wrangler secret put GEMINI_API_KEY